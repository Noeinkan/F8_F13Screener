# Configurazione 13F Alert System
# Copia questo file in .env e inserisci i tuoi valori

# Token del bot Telegram (ottienilo da @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Il tuo Chat ID Telegram (ottienilo da getUpdates)
TELEGRAM_CHAT_ID=123456789

# User Agent per SEC (deve includere il tuo email)
SEC_USER_AGENT=YourName yourname@email.com
